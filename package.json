{
  "name": "@tktb-tess/my-zod-schema",
  "version": "0.4.1",
  "type": "module",
  "license": "CC0-1.0",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tktb-tess/schemas.git"
  },
  "homepage": "https://github.com/tktb-tess/schemas/blob/main/README.md",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    },
    "./cotec_json": {
      "import": "./dist/cotec_json.js",
      "types": "./dist/cotec_json.d.ts"
    },
    "./otm_json": {
      "import": "./dist/otm_json.js",
      "types": "./dist/otm_json.d.ts"
    },
    "./comma_data": {
      "import": "./dist/comma_data.js",
      "types": "./dist/comma_data.d.ts"
    },
    "./zpdic": {
      "import": "./dist/zpdic.js",
      "types": "./dist/zpdic.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^6.0.2",
    "unified": "^11.0.5",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
  
}
